# Copy to .env and adjust. docker-compose reads this automatically.
# .env is gitignored; .env.example is the tracked template.

MYSQL_DB=jamsserver
MYSQL_USER=jams
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

# Administrator account, created (hashed) on first start.
# If ADMIN_PASSWORD is left empty, a random one is generated and written to the
# server log once. Change the password after the first login.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-me-admin

# Max heap for a single model run (passed to the model JVM).
SERVER_MAX_MEM=8g

# Host directory for all persistent data (bind-mounted). Put this on a partition
# with plenty of free space: it holds ${DATA_DIR}/data (uploads + per-job model
# execution dirs, which can grow large) and ${DATA_DIR}/db (the MySQL database).
# Create it with the right ownership before the first start (see INSTALL.md).
DATA_DIR=/home/jamscloud

# --- Optional TLS (only used by docker-compose.tls.yml) ---
# Default deployment (docker-compose.yml) is plain HTTP on 8080 and ignores these.
# For the TLS deployment, set the public host name and pick the TLS mode:
#   Self-signed (Caddy internal CA, no open ports needed; clients must trust it):
#     SERVER_NAME=xyz.uni-jena.de
#     CADDY_TLS=tls internal
#   Let's Encrypt (real cert; needs ports 80/443 reachable from the internet):
#     SERVER_NAME=xyz.uni-jena.de
#     CADDY_TLS=
SERVER_NAME=localhost
CADDY_TLS=tls internal
