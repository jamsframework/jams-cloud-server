# JAMS Cloud Server configuration (sample).
#
# The server reads these values from a file named "settings.properties" in its
# working directory (the Payara domain directory). Every value can instead be
# supplied via an environment variable, which takes precedence over this file —
# this is what the Docker setup uses, so the file is optional there.
#
#   property            environment variable   used by
#   upload-directory    UPLOAD_DIRECTORY       ApplicationConfig
#   tmp-directory       TMP_DIRECTORY          ApplicationConfig
#   exec-directory      EXEC_DIRECTORY         ApplicationConfig
#   server-max-mem      SERVER_MAX_MEM         ApplicationConfig (default 8g)
#   databaseUrl         DATABASE_URL           DBInit / Flyway
#   databaseUser        DATABASE_USER          DBInit / Flyway
#   databasePw          DATABASE_PASSWORD      DBInit / Flyway
#
# The JPA datasource (jdbc/jamsserver) is configured separately in
# WEB-INF/glassfish-resources.xml via MYSQL_HOST/PORT/DB/USER/PASSWORD.

upload-directory=/var/jamscloud/upload/
tmp-directory=/var/jamscloud/tmp/
exec-directory=/var/jamscloud/exec/
server-max-mem=8g

databaseUrl=jdbc:mysql://localhost:3306/jamsserver
databaseUser=jams
databasePw=jams
